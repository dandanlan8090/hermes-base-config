# ===== vdb 向量检索 API 密钥配置 =====
#
# 推荐：硅基流动 SiliconFlow（免费 2000 RPM / 500k TPM）
# 注册：https://siliconflow.cn
# 模型：BAAI/bge-m3（多语言 1024d）
#
# 使用前至少配置一个 API Key，二选一：

SILICONFLOW_API_KEY=sk-your-siliconflow-key-here

# 备选：NVIDIA NIM（延迟 ~6s/query，不推荐日常使用）
# NVIDIA_API_KEY=nvapi-your-key-here

# 如果你使用 OpenAI 兼容的其他向量 API，修改 embed.py 的 API_URL 和 MODEL
